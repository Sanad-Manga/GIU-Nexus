PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/giu-nexus?appName=Cluster0
JWT_SECRET=your-jwt-secret-here
ADMIN_REGISTRATION_SECRET=your-admin-registration-secret
JWT_EXPIRE=7d
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_HOST=your-email-host-here
EMAIL_PORT=587
EMAIL_USER=your-email-here // your own email address
EMAIL_PASS=your-email-password-here 

/* steps to get this:

1. Go to your Google Account

Visit myaccount.google.com
Make sure you're signed in with the email you put in EMAIL_USER

2. Enable 2-Step Verification (required first)

Click Security on the left sidebar
Scroll down to find "2-Step Verification"
Click it and follow the steps to turn it on (just takes 2 minutes)

3. Generate the App Password

Go to myaccount.google.com/apppasswords directly
It'll ask you to sign in again
In the "App name" field, type anything like GIU Nexus
Click Create
Google will show you a 16-character password like abcd efgh ijkl mnop

4. Copy it into your .env
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=abcdefghijklmnop

*/