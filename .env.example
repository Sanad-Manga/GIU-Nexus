PORT=5000

#Database setup
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/giu-nexus?appName=Cluster0

JWT_SECRET=your-jwt-secret-here
JWT_EXPIRE=7d

ADMIN_REGISTRATION_SECRET=your-admin-registration-secret

#Hugging face token
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

#Required for nodemailer to work (forgot password)
EMAIL_HOST=your-email-host-here
EMAIL_PORT=587
EMAIL_USER=your-email-here // your own email address
EMAIL_PASS=your-email-password-here 

#cloudinary credentials for the Profile picture to work
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret